# Chili Piper Slot Scraper Configuration
# Copy this file to .env and update with your values
# NEVER commit .env to version control

# Target Chili Piper Form URL (configurable)
CHILI_PIPER_FORM_URL=https://cincpro.chilipiper.com/concierge-router/link/lp-request-a-demo-agent-advice

# Server Configuration
NODE_ENV=production
PORT=3000

# Security - REQUIRED: Generate strong secrets
# Generate JWT_SECRET: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# API Authentication
# Set your API key(s) - comma-separated for multiple keys
DEFAULT_API_KEY=your-api-key-here
API_KEYS=key1,key2,key3

# Admin Authentication - REQUIRED: Change these!
# Generate password hash: node scripts/generate-password-hash.js yourpassword
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$92IXUNpkjO0rOQ5byMi.Ye4oKoEa3Ro9llC/.og/at2.uheWG/igi

# Scraping Configuration
MAX_SCRAPING_TIMEOUT=30000
MAX_DAYS_TO_COLLECT=7

# Concurrency Configuration
# Maximum concurrent operations (scraping + booking) (default: 15)
MAX_CONCURRENT_REQUESTS=15
# Maximum queue size for pending requests (default: 50)
MAX_QUEUE_SIZE=50
# Queue timeout in milliseconds (default: 30000 = 30 seconds)
QUEUE_TIMEOUT_MS=30000
# Maximum browser instances in pool (default: 2)
MAX_BROWSER_POOL_SIZE=2

# Browser Instance Persistence Configuration
# Maximum persistent browser instances (per email) (default: 50)
MAX_BROWSER_INSTANCES=50
# Timeout for persistent instances in milliseconds (default: 900000 = 15 minutes)
BROWSER_INSTANCE_TIMEOUT_MS=900000

# Calendly booking – base URL and form mode
# If set, used as the Calendly event base (e.g. referral program with name/email/phone only).
# Example: https://calendly.com/pay-per-closing/exclusive-referral-program-agent-advice
# If unset, defaults to AgentFire demo (30-minute-demo with full questionnaire).
# CALENDLY_BASE_URL=https://calendly.com/pay-per-closing/exclusive-referral-program-agent-advice
# Set to 1 or true when the event only has name, email, and phone (no extra questions).
# Can be inferred from CALENDLY_BASE_URL containing "exclusive-referral-program-agent-advice" if unset.
# CALENDLY_SIMPLE_FORM=1
# Optional regex for success URL after booking (e.g. calendly\.com.*scheduled).
# In simple-form mode, when unset, we use generic success (e.g. "scheduled"/"confirmed" text on page).
# CALENDLY_CONFIRMATION_URL_REGEX=
# When using POST /api/book with vendor=housejet-ppc, this URL is used (default: pay-per-closing/exclusive-referral-program-agent-advice).
# CALENDLY_REFERRAL_BASE_URL=https://calendly.com/pay-per-closing/exclusive-referral-program-agent-advice

# Rotating proxy for housejet-ppc bookings only (e.g. Smartproxy – new IP per booking).
# When set, only the browser context used for housejet-ppc Calendly bookings uses this proxy.
# Smartproxy – residential proxy with user auth: proxy.smartproxy.net, port 3120.
# Smartproxy – rotating (other endpoints): e.g. gate.smartproxy.com:7000. Get credentials from dashboard.
# HOUSEJET_PPC_PROXY_SERVER=http://proxy.smartproxy.net:3120
# HOUSEJET_PPC_PROXY_USERNAME=your-smartproxy-username
# HOUSEJET_PPC_PROXY_PASSWORD=your-smartproxy-password

# CapSolver API – reCAPTCHA v3 Enterprise (Calendly)
# When both CAPSOLVER_API_KEY and CALENDLY_RECAPTCHA_WEBSITE_KEY are set, the app solves reCAPTCHA v3 Enterprise
# via CapSolver before clicking Schedule Event. The same proxy as the booking (e.g. HOUSEJET_PPC_* above) is used when set.
# Get website key from Calendly page source or CapSolver extension: https://docs.capsolver.com/en/blog/show-to-get-recaptcha-version/
# CAPSOLVER_API_KEY=CAP-xxxx
# CALENDLY_RECAPTCHA_WEBSITE_KEY=6Lxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CALENDLY_RECAPTCHA_PAGE_ACTION=scheduling
# CALENDLY_RECAPTCHA_API_DOMAIN=www.recaptcha.net
# CALENDLY_RECAPTCHA_ENTERPRISE_S=

# CapSolver Chrome extension (housejet-ppc / payperclose Calendly only)
# When set, payperclose bookings use a browser with the CapSolver extension loaded for in-page reCAPTCHA solving.
# Download unpacked extension from https://github.com/capsolver/capsolver-browser-extension/releases and set path.
# CAPSOLVER_EXTENSION_PATH=capsolver-extension
# Same key as used by the CapSolver API (recaptcha-solver); required for the extension.
# CAPSOLVER_API_KEY=CAP-xxxx
# Optional: number of extension-enabled browser slots (default: 1).
# CAPSOLVER_POOL_SIZE=1

# Calendly booking – video recording on failure
# Set to 0 or false to disable (default: enabled)
# CALENDLY_VIDEO_ENABLED=1
# Directory for recordings (default: .calendly-videos); failed runs are saved under failed/
# CALENDLY_VIDEO_DIR=.calendly-videos

# Public video gallery – list and download failed Calendly videos at /calendly-videos
# Set to 1 or true to enable (default: disabled)
# CALENDLY_VIDEO_GALLERY_ENABLED=0

# Chili Piper booking – video recording on failure
# Set to 0 or false to disable (default: enabled)
# CHILI_PIPER_VIDEO_ENABLED=1
# Directory for recordings (default: .chili-piper-videos); failed runs are saved under failed/
# CHILI_PIPER_VIDEO_DIR=.chili-piper-videos
